   ['Spinach','https://www.maangchi.com/wp-content/uploads/2007/09/spinach-1.jpg'],
   ['Tea','https://cff2.earth.com/uploads/2022/07/29091859/Green-tea-scaled.jpg']
  ],
  Anemia:[
   ['Beetroot','https://images-prod.healthline.com/hlcmsresource/images/AN_images/AN172-Beets-1296x728-Header.jpg'],
   ['Orange','https://www.pngarts.com/files/3/Orange-Slice-Transparent-Images.png'],
   ['Spinach','https://www.maangchi.com/wp-content/uploads/2007/09/spinach-1.jpg'],
   ['Dates','https://www.tastingtable.com/img/gallery/15-types-of-date-fruits-explained/l-intro-1671030210.jpg']
  ]
 };

 let html='';
 data[type].forEach(f=>{
  html+=`<div class="card"><img src="${f[1]}"><p>${f[0]}</p></div>`;
 });

 document.getElementById('womenResult').innerHTML=html;
}


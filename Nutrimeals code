/* TRACKER */
let chart;

function saveWeight(){
 let w=document.getElementById('trackWeight').value;
 if(!w) return;

 let arr=JSON.parse(localStorage.getItem('weights')||"[]");
 arr.push(w);
 localStorage.setItem('weights',JSON.stringify(arr));
 showHistory();
 drawChart();
}

function showHistory(){
 let arr=JSON.parse(localStorage.getItem('weights')||"[]");
 let html='';
 arr.forEach((w,i)=>{
  html+=`<div class="card">Day ${i+1}: ${w} kg</div>`;
 });
 document.getElementById('history').innerHTML=html;
}

function drawChart(){
 let arr=JSON.parse(localStorage.getItem('weights')||"[]");
 let ctx=document.getElementById('chart');

 if(chart) chart.destroy();

 chart=new Chart(ctx,{
  type:'line',
  data:{
   labels:arr.map((_,i)=>"Day "+(i+1)),
   datasets:[{label:'Weight',data:arr}]
  }
 });
}

showHistory();
drawChart();

</script>

</body>
</html>

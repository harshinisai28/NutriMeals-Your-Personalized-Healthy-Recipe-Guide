 let data={
  Underweight:[
   ['https://img.freepik.com/premium-photo/realistic-glass-bottle-milk-twisted-splash-blue-background-eps10-vector_1199132-83890.jpg','Milk'],
   ['https://www.tastingtable.com/img/gallery/the-real-difference-between-bananas-and-baby-bananas/l-intro-1663622196.jpg','Banana']
  ],
  Normal:[
   ['https://evergreenkitchen.ca/wp-content/uploads/2023/01/Overnight-Oats-with-Coconut-Milk-Evergreen-Kitchen-1.jpg','Oats'],
   ['https://png.pngtree.com/background/20230606/original/pngtree-fruits-wallpaper-fruit-wallpaper-picture-image_2884694.jpg','Fruits']
  ],
  Overweight:[
   ['https://cff2.earth.com/uploads/2022/07/29091859/Green-tea-scaled.jpg','Green Tea'],
   ['https://images2.alphacoders.com/719/thumb-1920-719435.jpg','Apple']
  ]
 };

 let html='';
 data[type].forEach(f=>{
  html+=`<div class="card"><img src="${f[0]}"><p>${f[1]}</p></div>`;
 });

 document.getElementById('mealPlan').innerHTML=html;
}

